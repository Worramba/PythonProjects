print("Food Quiz")

score = 0

def quiz_maker(question, correct_answer):
    global score
    answer = input(question + ": ")

    if answer.lower() == correct_answer:
        print("Correct!")
        score += 1
    else:
        print("Wrong!")

quiz_maker("1. What fruit is red", "apple")
quiz_maker("2. What fruit is yellow", "banana")
quiz_maker("3. What food is made from milk and on pizza", "cheese")

print("Your score is", score)
